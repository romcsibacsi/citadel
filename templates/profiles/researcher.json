{
  "id": "researcher",
  "label": "Kutató",
  "description": "Piackutatás, versenytárs-elemzés, webes források olvasása. Prompt injection szempontból ugyanúgy kiemelt mint a marketinges. Draft-only: riportot ír a mappájába, nem küld magától kifelé.",
  "permissionMode": "strict",
  "filesystem": {
    "allow": [
      "Read(${AGENT_DIR}/**)",
      "Write(${AGENT_DIR}/**)",
      "Edit(${AGENT_DIR}/**)",
      "Read(${HOME}/Downloads/**)",
      "Bash(ls:*)",
      "Bash(cat:*)",
      "WebFetch(*)",
      "WebSearch(*)"
    ],
    "deny": [
      "Read(${HOME}/.ssh/**)",
      "Read(${HOME}/.aws/**)",
      "Read(${HOME}/.gnupg/**)",
      "Read(${HOME}/.env)",
      "Read(**/.env)",
      "Bash(sudo:*)",
      "Bash(rm:*)",
      "Bash(curl -X POST:*)",
      "Bash(git push:*)"
    ]
  }
}
