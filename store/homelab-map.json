  "_meta": {
    "purpose": "Homelab-status page container->display mapping. FORGE joins Uptime Kuma /metrics monitor_name -> this map (key).",
    "prism_spec": "agents/prism/specs/homelab-docker-status-page.md (Variant B + 15s refresh)",
    "status_source": "Uptime Kuma /metrics (Prometheus)",
    "status_endpoint": "http://192.168.1.105:8102/metrics",
    "status_auth": "HTTP basic: empty username, password = vault:Api (Kuma metrics API key; resolve via vault, never hardcode)",
    "status_join_key": "Kuma monitor_status{monitor_name=\"X\"} == this map's key X",
    "status_value_map": { "1": "up", "0": "down", "2": "restarting", "3": "unknown", "missing": "unknown" },
    "group_order": ["media", "mail", "monitoring", "web", "infra"],
    "fields_note": "display=UI label, group=section, webui_url=clickable link (null=no web UI), port=primary port, docker_name=container for dedup, description=pár szavas magyar tooltip (FORGE: hover-tooltip).",
    "webui_url_null_means": "no clickable web UI from the LAN (only Mailcow SMTP:25 now) -> name NOT a link (PRISM §5.3)",
    "docker_name_note": "Exact docker container name for the collapsed-internal dedup (FORGE mappedDockerNames() excludes these from `docker ps`). null = not a container (CITADEL Dashboard is a host process).",
    "internal_collapsed_note": "The 31 entries are the user-facing monitors. Internal sub-containers (mailcow ~18, *-db/*-redis, mcp-*, sidecars) are NOT in Kuma; for the collapsed 'Belső szolgáltatások' use `docker ps -a` MINUS the docker_name values below.",
    "uptime_pct_note": "Kuma /metrics has monitor_response_time (latency) but NO uptime%. v1: show latency, uptime%=null (FORGE confirmed coded this way). uptime% would need a slow socket.io poll (vault:KUMA_ADMIN_USER/PASS) -> NOT the 15s hot path.",
    "webui_url_caveats": [
      "Paperless-ngx: only serves via https://docs.uplinkfather.com (NPM ingress); LAN-IP:8050 returns 400 (PAPERLESS_ALLOWED_HOSTS=docs.uplinkfather.com,localhost). Link uses the domain.",
      "AdGuard: admin UI moved to :80 (published 8193) after setup; :8093 (3000) is setup-only and now closed.",
      "Obsidian: web UI is basic-auth gated (HTTP 401) — browser will prompt for credentials.",
      "IPFS: admin is the WebUI at :5001/webui (the :5001 root is the API, not a UI)."
    ],
    "open_items": [
      "No 'Uptime Kuma' self-monitor (Kuma can't reliably monitor itself). FORGE derives Kuma=up from a successful /metrics fetch."
    ]
  },
