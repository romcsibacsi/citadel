REBUILD_PROMPT.md
REBUILD_PROMPT_V2.md
alkuszokatas_dashboard.md
napindito-prompt.md
scheduled-tasks.json
citadel.log

# Local backup archives from scripts/backup.sh
backups/

# Agent-local seed skills are product templates (tracked); the live copies
# under agents/<name>/.claude/skills/ remain ignored via agents/ above.
!seed-agents/*/.claude/
!seed-agents/*/.claude/skills/
!seed-agents/*/.claude/skills/**
