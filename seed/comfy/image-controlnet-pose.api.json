{
  "_comment": "ComfyUI API-format SDXL + ControlNet (pose) graph (FIX-plugin-comfy-workflows §5). A reference pose image is run through a DWPose/OpenPose preprocessor, then ControlNetApplyAdvanced conditions the SDXL render on that pose. CUSTOM NODES — the service probes hasNode('ControlNetLoader') + hasNode('DWPreprocessor') (OpenPose fallback) and returns a clear 'not installed' message otherwise. <<control_net_name>> from /object_info/ControlNetLoader; <<pose_image>> from /upload/image; <<strength>> is the ControlNet strength.",
  "4": { "class_type": "CheckpointLoaderSimple", "inputs": { "ckpt_name": "<<checkpoint>>" } },
  "5": { "class_type": "EmptyLatentImage", "inputs": { "width": "<<width>>", "height": "<<height>>", "batch_size": 1 } },
  "6": { "class_type": "CLIPTextEncode", "inputs": { "text": "<<prompt>>", "clip": ["4", 1] } },
  "7": { "class_type": "CLIPTextEncode", "inputs": { "text": "<<negative>>", "clip": ["4", 1] } },
  "40": { "class_type": "LoadImage", "inputs": { "image": "<<pose_image>>" } },
  "41": { "class_type": "DWPreprocessor", "inputs": { "image": ["40", 0], "detect_hand": "enable", "detect_body": "enable", "detect_face": "enable" } },
  "42": { "class_type": "ControlNetLoader", "inputs": { "control_net_name": "<<control_net_name>>" } },
  "43": { "class_type": "ControlNetApplyAdvanced", "inputs": {
    "positive": ["6", 0], "negative": ["7", 0], "control_net": ["42", 0], "image": ["41", 0],
    "strength": "<<strength>>", "start_percent": 0, "end_percent": 1
  } },
  "3": { "class_type": "KSampler", "inputs": {
    "seed": "<<seed>>", "steps": "<<steps>>", "cfg": "<<cfg>>",
    "sampler_name": "euler", "scheduler": "normal", "denoise": 1,
    "model": ["4", 0], "positive": ["43", 0], "negative": ["43", 1], "latent_image": ["5", 0]
  } },
  "8": { "class_type": "VAEDecode", "inputs": { "samples": ["3", 0], "vae": ["4", 2] } },
  "9": { "class_type": "SaveImage", "inputs": { "filename_prefix": "<<prefix>>", "images": ["8", 0] } }
}
