{
  "_comment": "ComfyUI API-format inpaint graph (FIX-plugin-comfy-workflows §3). A source image + a mask (white = repaint) are VAE-encoded for inpaint, then KSampler regenerates the masked region. For OUTPAINT the caller pads the image + mask border first (a separate ImagePadForOutpaint variant is added at build time). <<source_image>> + <<mask_image>> are /upload/image names; denoise is the strength.",
  "4": { "class_type": "CheckpointLoaderSimple", "inputs": { "ckpt_name": "<<checkpoint>>" } },
  "10": { "class_type": "LoadImage", "inputs": { "image": "<<source_image>>" } },
  "12": { "class_type": "LoadImage", "inputs": { "image": "<<mask_image>>" } },
  "13": { "class_type": "VAEEncodeForInpaint", "inputs": { "pixels": ["10", 0], "vae": ["4", 2], "mask": ["12", 1], "grow_mask_by": 6 } },
  "6": { "class_type": "CLIPTextEncode", "inputs": { "text": "<<prompt>>", "clip": ["4", 1] } },
  "7": { "class_type": "CLIPTextEncode", "inputs": { "text": "<<negative>>", "clip": ["4", 1] } },
  "3": { "class_type": "KSampler", "inputs": {
    "seed": "<<seed>>", "steps": "<<steps>>", "cfg": "<<cfg>>",
    "sampler_name": "euler", "scheduler": "normal", "denoise": "<<denoise>>",
    "model": ["4", 0], "positive": ["6", 0], "negative": ["7", 0], "latent_image": ["13", 0]
  } },
  "8": { "class_type": "VAEDecode", "inputs": { "samples": ["3", 0], "vae": ["4", 2] } },
  "9": { "class_type": "SaveImage", "inputs": { "filename_prefix": "<<prefix>>", "images": ["8", 0] } }
}
