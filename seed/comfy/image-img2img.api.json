{
  "_comment": "ComfyUI API-format img2img graph for an SD/SDXL checkpoint (FIX-plugin-comfy-workflows §1). A source image is VAE-encoded to a latent, then KSampler refines it with denoise < 1 (the strength knob, 0.3-0.8). Replace every <<token>>; numeric tokens MUST become real JSON numbers. The source image name (<<source_image>>) is the name returned by /upload/image.",
  "4": { "class_type": "CheckpointLoaderSimple", "inputs": { "ckpt_name": "<<checkpoint>>" } },
  "10": { "class_type": "LoadImage", "inputs": { "image": "<<source_image>>" } },
  "11": { "class_type": "VAEEncode", "inputs": { "pixels": ["10", 0], "vae": ["4", 2] } },
  "6": { "class_type": "CLIPTextEncode", "inputs": { "text": "<<prompt>>", "clip": ["4", 1] } },
  "7": { "class_type": "CLIPTextEncode", "inputs": { "text": "<<negative>>", "clip": ["4", 1] } },
  "3": { "class_type": "KSampler", "inputs": {
    "seed": "<<seed>>", "steps": "<<steps>>", "cfg": "<<cfg>>",
    "sampler_name": "euler", "scheduler": "normal", "denoise": "<<denoise>>",
    "model": ["4", 0], "positive": ["6", 0], "negative": ["7", 0], "latent_image": ["11", 0]
  } },
  "8": { "class_type": "VAEDecode", "inputs": { "samples": ["3", 0], "vae": ["4", 2] } },
  "9": { "class_type": "SaveImage", "inputs": { "filename_prefix": "<<prefix>>", "images": ["8", 0] } }
}
