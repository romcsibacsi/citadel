# CITADEL konfiguráció
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
ALLOWED_CHAT_ID=your_telegram_chat_id
OWNER_NAME=Your Name
HEARTBEAT_CALENDAR_ID=your_calendar_id_or_email
# Opcionális:
# WEB_PORT=3420
# WEB_HOST=127.0.0.1       # FONTOS: 0.0.0.0-val a dashboard elérhető a hálózatról. Használj DASHBOARD_TOKEN-t!
# OLLAMA_URL=http://localhost:11434
# CITADEL_ENV=linux-server  # platform override: macos | linux-server | linux-gui
# GOOGLE_API_KEY=your_google_api_key
# --- ntfy one-way push (heartbeat escalations, task completions, alerts) ---
# Both NTFY_URL and NTFY_TOPIC required to enable; otherwise push is a no-op.
# NTFY_URL=https://ntfy.sh            # or your self-hosted ntfy base URL
# NTFY_TOPIC=citadel-alerts           # the topic to publish to
# NTFY_TOKEN=                         # optional: bearer token for protected topics
# NTFY_PRIORITY=                      # optional default: min|low|default|high|urgent
# --- Phase 6: hybrid heartbeat triage ---
# Always-on CPU pre-filter: decides whether anything is worth surfacing
# BEFORE the heartbeat wakes the interactive Claude sub-agent. ON by default
# (only relevant when HEARTBEAT_AGENT_ENABLED=1). Set to 0 to restore the
# legacy "always escalate" behavior.
# HEARTBEAT_TRIAGE_ENABLED=1
# Optional, fallback-first WSL-GPU Ollama boost. Leave URL empty (default)
# to run heuristic-only. When set, the gate asks a small local model for a
# second opinion but NEVER blocks on it: an unreachable endpoint, a timeout,
# or a bad response silently falls back to the heuristic decision. The URL
# must be reachable FROM the dashboard host (e.g. the WSL distro's IP, not
# "localhost", if the dashboard runs outside WSL).
# HEARTBEAT_TRIAGE_OLLAMA_URL=        # e.g. http://172.20.0.2:11434 (empty = boost off)
# HEARTBEAT_TRIAGE_OLLAMA_MODEL=llama3.2:1b
# HEARTBEAT_TRIAGE_OLLAMA_TIMEOUT_MS=4000
